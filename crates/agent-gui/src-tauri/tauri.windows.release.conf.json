{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "Calen",
        "width": 1400,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 720,
        "backgroundThrottling": "disabled",
        "decorations": false
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/stock-sidecar/": "stock-sidecar/",
      "resources/translation-runtime/": "translation-runtime/",
      "icons/icon-windows.ico": "calen-icon.ico"
    },
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32-windows.png",
      "icons/128x128-windows.png",
      "icons/128x128@2x-windows.png",
      "icons/icon-windows.png",
      "icons/icon-windows.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "dialogImagePath": "icons/wix-dialog.bmp"
      },
      "nsis": {
        "installerIcon": "icons/icon-windows.ico",
        "uninstallerIcon": "icons/icon-windows.ico",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  }
}
