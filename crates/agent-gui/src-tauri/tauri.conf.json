{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calen",
  "version": "../package.json",
  "identifier": "com.xiaofei.liveagent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 720,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.calen/backgrounds/**",
          "$HOME/.liveagent/backgrounds/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxODk1OUIxQkMxNjQwQkYKUldTL1FCYThzVm1Ka1VVWDkvclIyVGQ5TmZBRFR6ZzFRME1EVGU2NnVlcEdCRGtsaFQrWXUwU3oK",
      "endpoints": []
    }
  }
}
